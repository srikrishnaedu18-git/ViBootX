{
  "manifest_version": 3,
  "name": "ViBootX",
  "version": "1.2.0",
  "description": "Semester filter and auto-search helper for VTOP course materials.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://vtop.vit.ac.in/vtop/content/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
